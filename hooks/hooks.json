{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__loomcycle__spawn_run",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture-run-telemetry.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__loomcycle__spawn_run|mcp__loomcycle__restore_snapshot|mcp__loomcycle__register_agent|mcp__loomcycle__unregister_agent|mcp__loomcycle__pause_runtime|mcp__loomcycle__resume_runtime",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/auto-snapshot-on-error.sh\""
          }
        ]
      }
    ]
  }
}
